# =============================================================================
# VibeCart Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# =============================================================================
# REQUIRED: Core Application
# =============================================================================

# Supabase Configuration
# For local development, these defaults work with Docker Compose
# For production, use your Supabase Cloud credentials
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Direct database connection (for migrations and external tools)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar-MA

# =============================================================================
# REQUIRED: Security
# =============================================================================

# Webhook API Key for securing legacy webhook endpoints
# Generate with: node -e "console.log('vk_' + require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 64 characters
WEBHOOK_API_KEY=

# =============================================================================
# REQUIRED: Instagram Integration
# =============================================================================
# Create a Meta App at: https://developers.facebook.com
# Add "Instagram Basic Display" product

INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# OAuth redirect URI - must match exactly in Meta Developer Console
# For local dev with ngrok: https://YOUR-DOMAIN.ngrok-free.app/api/auth/instagram/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# Encryption key for storing Instagram tokens (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hexadecimal characters (32 bytes)
INSTAGRAM_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# =============================================================================
# REQUIRED: WhatsApp Business Integration
# =============================================================================
# Use the same Meta App as Instagram, or create a separate one
# Add "WhatsApp" product in Meta Developer Console

WHATSAPP_APP_ID=your-whatsapp-app-id
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# OAuth redirect URI for WhatsApp Business authentication
# For local dev with ngrok: https://YOUR-DOMAIN.ngrok-free.app/api/auth/whatsapp/callback
WHATSAPP_REDIRECT_URI=http://localhost:3000/api/auth/whatsapp/callback

# Encryption key for storing WhatsApp tokens (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hexadecimal characters (32 bytes)
WHATSAPP_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Webhook verification token - used to verify webhook requests from Meta
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in Meta Developer Console webhook configuration
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# =============================================================================
# OPTIONAL: SMS/Phone Authentication
# =============================================================================
# Configure Twilio for production SMS delivery
# https://www.twilio.com/console

# Set to true for development (any 6-digit code works, no SMS sent)
# Set to false for production (requires valid Twilio credentials)
SMS_AUTOCONFIRM=true

# Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token
TWILIO_AUTH_TOKEN=

# Twilio Messaging Service SID (starts with MG...)
# Create at: https://console.twilio.com/us1/develop/sms/services
TWILIO_MESSAGE_SERVICE_SID=

# =============================================================================
# OPTIONAL: Google OAuth Authentication
# =============================================================================
# Enable Google sign-in for users
# https://console.cloud.google.com/apis/credentials

# Set to true to enable Google OAuth
GOOGLE_OAUTH_ENABLED=false

# Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# Google OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=

# =============================================================================
# OPTIONAL: AI Features (Google Gemini)
# =============================================================================
# Required for AI-powered content generation features
# https://ai.google.dev/gemini-api/docs/api-key

GEMINI_API_KEY=

# =============================================================================
# OPTIONAL: Local Development Tools
# =============================================================================
# These are only needed for local development with Instagram OAuth

# ngrok authentication token
# Get yours at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ngrok static domain (free with ngrok account)
# Get yours at: https://dashboard.ngrok.com/cloud-edge/domains
# Example: your-app-name.ngrok-free.app (without https://)
NGROK_DOMAIN=

# =============================================================================
# PRODUCTION CONFIGURATION TEMPLATE
# =============================================================================
# Uncomment and fill in these values for production deployment
# =============================================================================

# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/auth/instagram/callback
# WHATSAPP_REDIRECT_URI=https://your-domain.com/api/auth/whatsapp/callback

# SMS_AUTOCONFIRM=false
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_MESSAGE_SERVICE_SID=your-twilio-messaging-service-sid

# GOOGLE_OAUTH_ENABLED=true
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Never commit .env.local to version control
# 2. Use different credentials for local and production
# 3. Rotate API keys regularly (see SECURITY.md)
# 4. Keep encryption keys secure - loss = data cannot be decrypted
# 5. Use strong, randomly generated secrets (not passwords or phrases)
# =============================================================================
