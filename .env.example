# VibeCart Environment Variables
# Copy this to .env.local and fill in the values

# ===================
# Supabase Configuration
# ===================
# For local development with Docker (run: docker compose -f docker/docker-compose.yml up -d)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# For production (Supabase Cloud)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Direct database connection (for migrations)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres

# ===================
# SMS/Phone Authentication
# ===================
# Set to true for development (no real SMS sent, any 6-digit code works)
# Set to false for production with real Twilio SMS
SMS_AUTOCONFIRM=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGE_SERVICE_SID=

# ===================
# Google OAuth
# ===================
# Set to true and provide credentials to enable Google sign-in
# Create OAuth 2.0 Client at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===================
# External Services
# ===================
# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Instagram Graph API (for OAuth and video embedding)
# Create a Meta App at: https://developers.facebook.com
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INSTAGRAM_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# WhatsApp Webhook Verification (optional)
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar-MA
